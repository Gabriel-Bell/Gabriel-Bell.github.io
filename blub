<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vaccine Mandates: Gabriel Bell</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@700&family=Lato:wght@300;400;700&display=swap');

        :root {
            --navy: #002147;
            --gold: #C5B358;
            --white: #FFFFFF;
            --gray: #F8F9FA;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Lato', sans-serif;
            background-color: #111;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
        }

        #deck {
            width: 100%;
            height: 100%;
            background: var(--white);
            position: relative;
            display: flex;
            flex-direction: column;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }

        .slide {
            position: absolute;
            inset: 0;
            padding: 80px;
            display: none;
            flex-direction: column;
            justify-content: center;
            background: white;
            animation: fadeIn 0.3s ease;
        }

        .slide.active { display: flex; }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* Style elements */
        .slide::before {
            content: "";
            position: absolute;
            top: 0; left: 0; width: 100%; height: 12px;
            background: linear-gradient(90deg, var(--navy), var(--gold));
        }

        h1 { font-family: 'Poppins', sans-serif; font-size: 5rem; color: var(--navy); line-height: 1; text-transform: uppercase; margin-bottom: 20px; }
        h2 { font-family: 'Poppins', sans-serif; font-size: 3rem; color: var(--navy); border-bottom: 6px solid var(--gold); display: inline-block; padding-bottom: 10px; margin-bottom: 50px; text-transform: uppercase; }
        
        .keyword { font-size: 2.2rem; font-weight: 700; color: #333; margin-bottom: 30px; display: flex; align-items: center; }
        .keyword i { color: var(--gold); margin-right: 25px; font-size: 2rem; width: 50px; text-align: center; }

        .stat-card { background: var(--gray); padding: 40px; border-radius: 20px; text-align: center; border: 1px solid #ddd; }
        .stat-value { font-family: 'Poppins', sans-serif; font-size: 8rem; color: var(--gold); line-height: 1; font-weight: 700; }
        .stat-label { font-size: 1.5rem; font-weight: 700; color: var(--navy); margin-top: 10px; text-transform: uppercase; }

        .layout-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }

        /* Navigation UI */
        .controls {
            position: fixed;
            bottom: 40px;
            right: 40px;
            display: flex;
            gap: 15px;
            z-index: 100;
        }

        .btn {
            background: var(--navy);
            color: white;
            border: none;
            width: 70px;
            height: 70px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 1.8rem;
            transition: 0.2s;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }

        .btn:hover { background: var(--gold); transform: scale(1.1); }

        .progress {
            position: fixed;
            bottom: 40px;
            left: 40px;
            background: rgba(0, 33, 71, 0.1);
            padding: 12px 25px;
            border-radius: 30px;
            font-weight: 700;
            color: var(--navy);
            z-index: 100;
            font-size: 1.2rem;
        }

        /* Special Slide Styles */
        .dark-slide { background: var(--navy) !important; color: white !important; text-align: center; }
        .dark-slide h1 { color: var(--gold) !important; border-bottom: 5px solid white; display: inline-block; padding-bottom: 20px; }
        .dark-slide .concept { font-size: 3.5rem; font-weight: 700; color: var(--gold); letter-spacing: 5px; margin-top: 30px; text-transform: uppercase; }

        .begin-btn {
            margin-top: 50px;
            padding: 20px 50px;
            font-size: 1.5rem;
            font-weight: 700;
            background: var(--navy);
            color: white;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            text-transform: uppercase;
            transition: 0.2s;
        }
        .begin-btn:hover { background: var(--gold); }
    </style>
</head>
<body>

    <div id="deck">
        <!-- SLIDE 1: TITLE -->
        <section class="slide active" style="text-align: center;">
            <h1>VACCINE MANDATES</h1>
            <p style="font-size: 3rem; color: var(--navy); margin-top: 10px; font-weight: 300; letter-spacing: 4px;">BY GABRIEL BELL</p>
            <p style="font-size: 1.2rem; color: var(--gold); margin-top: 40px; font-style: italic;">Slideshow made in collaboration with Google Gemini</p>
            <button class="begin-btn" onclick="nextSlide()">Begin Presentation</button>
        </section>

        <!-- SLIDE 2: EFFICACY -->
        <section class="slide">
            <h2>Efficacy Realities</h2>
            <div class="layout-grid">
                <div class="stat-card">
                    <div class="stat-value">19%</div>
                    <div class="stat-label">Low-End CDC Data (2025)</div>
                </div>
                <div>
                    <div class="keyword"><i class="fas fa-arrows-split-up"></i> Strain Mismatch</div>
                    <div class="keyword"><i class="fas fa-hourglass-half"></i> Waning Immunity</div>
                    <div class="keyword"><i class="fas fa-chart-line-down"></i> Variable Protection</div>
                </div>
            </div>
        </section>

        <!-- SLIDE 3: SAFETY -->
        <section class="slide">
            <h2>Safety Concerns</h2>
            <div style="margin-top: 20px;">
                <div class="keyword"><i class="fas fa-triangle-exclamation"></i> Guillain-Barré Syndrome</div>
                <div class="keyword"><i class="fas fa-file-medical"></i> Package Insert Warnings</div>
                <div class="keyword"><i class="fas fa-user-shield"></i> Autoimmune Response</div>
                <div class="keyword"><i class="fas fa-notes-medical"></i> Adverse Reaction Reports</div>
            </div>
        </section>

        <!-- SLIDE 4: LIABILITY -->
        <section class="slide">
            <h2>Legal Immunity</h2>
            <div class="layout-grid">
                <div class="stat-card">
                    <div class="stat-value">$5.6B</div>
                    <div class="stat-label">Total Injury Payouts</div>
                </div>
                <div>
                    <div class="keyword"><i class="fas fa-gavel"></i> 42 USC 300AA-22</div>
                    <div class="keyword"><i class="fas fa-shield-halved"></i> Liability Protection</div>
                    <div class="keyword"><i class="fas fa-handshake-slash"></i> Unavoidable Side Effects</div>
                </div>
            </div>
        </section>

        <!-- SLIDE 5: EVOLUTION -->
        <section class="slide">
            <h2>Evolutionary Escape</h2>
            <div style="margin-top: 20px;">
                <div class="keyword"><i class="fas fa-dna"></i> Genetic Mutation (HA Protein)</div>
                <div class="keyword"><i class="fas fa-virus-covid"></i> Antibody Evasion</div>
                <div class="keyword"><i class="fas fa-chart-line"></i> Selection Pressure</div>
                <div class="keyword"><i class="fas fa-rotate"></i> Evolutionary Treadmill</div>
            </div>
        </section>

        <!-- SLIDE 6: SOVEREIGNTY -->
        <section class="slide dark-slide">
            <h1>INDIVIDUAL SOVEREIGNTY</h1>
            <div style="margin-top: 50px;">
                <p class="concept">INFORMED CONSENT</p>
                <p class="concept">PERSONAL AUTONOMY</p>
            </div>
        </section>
    </div>

    <!-- UI -->
    <div class="progress">SLIDE <span id="slide-num">1</span> / 6</div>
    
    <div class="controls">
        <button class="btn" onclick="prevSlide()"><i class="fas fa-chevron-left"></i></button>
        <button class="btn" onclick="nextSlide()"><i class="fas fa-chevron-right"></i></button>
    </div>

    <script>
        let currentIdx = 0;
        const slides = document.querySelectorAll('.slide');
        const numText = document.getElementById('slide-num');

        function update() {
            slides.forEach((s, i) => {
                s.classList.toggle('active', i === currentIdx);
            });
            numText.innerText = currentIdx + 1;
        }

        function nextSlide() {
            currentIdx = (currentIdx + 1) % slides.length;
            update();
        }

        function prevSlide() {
            currentIdx = (currentIdx - 1 + slides.length) % slides.length;
            update();
        }

        // Keyboard Support
        document.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowRight' || e.key === ' ') nextSlide();
            if (e.key === 'ArrowLeft') prevSlide();
        });
    </script>
</body>
</html>
